# Next.js port for `next dev` / `next start`.
PORT=3000

# Server-only URL of the NestJS API. NEVER prefix with NEXT_PUBLIC_ — this URL
# must stay invisible to the browser. Used exclusively by Server Components
# and Route Handlers (BFF) running on the Node runtime.
BACKEND_URL=http://localhost:3001

# Public canonical origin of the web app. Used for absolute returnTo URLs and
# for setting Origin/Referer headers on server→server requests.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare Turnstile *site* key (public). Paired with the backend's
# CLOUD_FLARE_TURNSTILE_SECRET_KEY. Use 1x00000000000000000000AA for local dev
# (Cloudflare's always-passes test key).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
